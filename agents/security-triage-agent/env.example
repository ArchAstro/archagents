# Required env vars for the Security Triage Agent
# Copy to .env and fill in your values, then run ./deploy.sh
#
# All of these need to be set as ORG ENV VARS on the platform too
# (the scripts read them via `env.VAR_NAME`).

# GitHub PAT with `repo` scope. Auto-fix PRs and escalation issues
# post as this account.
GITHUB_TOKEN=ghp_your_token_here

# Default repo for scanning when no override is provided
DEFAULT_REPO_OWNER=your-org
DEFAULT_REPO_NAME=your-repo
DEFAULT_ECOSYSTEM=hex

# Comma-separated list of repos to monitor on the daily scan
MONITORED_REPOS=your-org/repo1,your-org/repo2

# (Optional) Where to send weekly triage summaries
SECURITY_TEAM_EMAIL=security@yourcompany.com

# (Optional) GCP log analysis
GCLOUD_PROJECT_ID=your-gcp-project
# Service account JSON. Use a read-only viewer role on Cloud Logging.
GCLOUD_SA_KEY={"type":"service_account",...}
