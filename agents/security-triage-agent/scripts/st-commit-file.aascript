// Create or update a file on a branch via the GitHub Contents API.
// Calls PUT /repos/{owner}/{repo}/contents/{path}
//
// content must be base64-encoded.

let http = import("requests")
let result = import("result")

let owner = $.owner
let repo = $.repo
let branch = $.branch
let path = $.path
let content = $.content
let message_text = $.message

// Try to fetch existing file SHA (for updates). 404 is fine — means new file.
let existing_result = http.get("https://api.github.com/repos/" + owner + "/" + repo + "/contents/" + path + "?ref=" + branch, {
  headers: {
    "Authorization": "Bearer " + env.GITHUB_TOKEN,
    "Accept": "application/vnd.github+json"
  }
})

let existing_sha = if (result.isOk(existing_result)) {
  let resp = unwrap(existing_result)
  if (resp.status == 200) { resp.body.sha } else { null }
} else {
  null
}

let body = if (existing_sha != null) {
  {
    "message": message_text,
    "content": content,
    "branch": branch,
    "sha": existing_sha
  }
} else {
  {
    "message": message_text,
    "content": content,
    "branch": branch
  }
}

let resp = unwrap(http.put("https://api.github.com/repos/" + owner + "/" + repo + "/contents/" + path, {
  headers: {
    "Authorization": "Bearer " + env.GITHUB_TOKEN,
    "Accept": "application/vnd.github+json"
  },
  body: body
}))

resp.body
