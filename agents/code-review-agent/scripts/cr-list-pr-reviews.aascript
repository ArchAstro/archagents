// List all reviews on a pull request.
// Used BEFORE posting a review to dedup against existing reviews from
// the same account.
// Calls GET /repos/{owner}/{repo}/pulls/{pull_number}/reviews

let http = import("requests")
let str = import("string")

let owner = $.owner
let repo = $.repo
let pull_number = $.pull_number

let url = "https://api.github.com/repos/" + owner + "/" + repo + "/pulls/" + str.toString(pull_number) + "/reviews"

let resp = unwrap(http.get(url, {
  headers: {
    "Authorization": "Bearer " + env.GITHUB_TOKEN,
    "Accept": "application/vnd.github+json"
  }
}))

resp.body
