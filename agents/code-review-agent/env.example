# Required env vars for the Code Review Agent
# Copy this file to .env and fill in your values, then run ./deploy.sh

# GitHub personal access token with `repo` scope.
# Reviews will post as this account. For a bot identity, create a PAT
# under a dedicated bot account or use a fine-grained token.
GITHUB_TOKEN=ghp_your_token_here

# (Optional) The bot's GitHub username — used by resolve_review_threads
# to identify which threads belong to the bot. Defaults to "" which
# disables thread resolution.
BOT_LOGIN=your-bot-username

# (Optional) Default repo for examples and tests. The webhook tells
# the agent which repo each PR is in, so this is just a fallback.
REPO_OWNER=your-org
REPO_NAME=your-repo
