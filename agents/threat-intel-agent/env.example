# Required env vars for the Threat Intelligence Agent
# Copy to .env, fill in your values, then run ./deploy.sh

# GitHub PAT with `repo` scope. Issues will post as this account.
GITHUB_TOKEN=ghp_your_token_here

# Comma-separated list of repos to check for exposure
MONITORED_REPOS=your-org/repo1,your-org/repo2

# Where to file the daily brief and exposure issues
BRIEF_REPO=your-org/your-repo

# One-line description of your stack — helps the agent decide what's relevant
STACK_DESCRIPTION="Python/Django backend, React frontend, AWS infra"

# Slack channel for the daily summary (e.g. #security)
SLACK_CHANNEL=#security
