# Required env vars for the Cross-Org Collaboration Agent
# Copy to .env and fill in your values, then run ./deploy.sh

# GitHub PAT with `repo` scope on your private repo. The agent uses this
# to read code (privately, in its reasoning context — not the chat) and
# to open PRs with actual implementation.
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub org and the repo the agent will read/write
REPO_OWNER=your-org
REPO_NAME=your-repo

# One-line description of your stack — used in the agent identity prompt
STACK_DESCRIPTION="Python/Django backend, React frontend, AWS infra"
