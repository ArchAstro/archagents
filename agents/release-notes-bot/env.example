# Required env vars for the Release Notes Bot
# Copy to .env, fill in your values, then run ./deploy.sh

# GitHub PAT with `repo` scope. Drafts will post as this account.
GITHUB_TOKEN=ghp_your_token_here

# The repo to watch and where to file the draft issues
REPO_OWNER=your-org
REPO_NAME=your-repo

# Branch to track for "merged" PRs
RELEASE_BRANCH=main
