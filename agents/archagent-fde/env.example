# The ArchAgents FDE agent has no required env vars out of the box —
# its only custom tool (`fetch_archagents_docs`) hits public docs.
#
# Add values here only if you want to customize the agent for a
# specific customer engagement. The identity prompt and skills do not
# read from the environment.

# Optional: override which customer's engagement context the FDE loads
# by default when the thread starts. The identity prompt does not use
# this directly; it is a convention for per-customer deployments.
# CUSTOMER_NAME=AcmeCo
